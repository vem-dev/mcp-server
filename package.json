{
	"name": "@vemdev/mcp-server",
	"version": "0.1.3",
	"description": "Official VEM MCP Server for AI agent project memory.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://vem.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/vem-dev/mcp-server.git"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ai-agent",
		"memory",
		"context",
		"vem",
		"project-memory",
		"claude",
		"cursor"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org",
		"provenance": true
	},
	"bin": {
		"vem-mcp": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"prebuild": "pnpm --filter @vem/schemas build && pnpm --filter @vem/core build",
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "latest",
		"find-up-simple": "^1.0.1",
		"fs-extra": "^11.3.3",
		"nanoid": "^5.1.6",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.3.1",
		"@vem/core": "workspace:*",
		"@vem/schemas": "workspace:*",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	}
}
